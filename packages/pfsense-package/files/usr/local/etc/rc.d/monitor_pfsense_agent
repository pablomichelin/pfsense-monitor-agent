#!/bin/sh

# PROVIDE: monitor_pfsense_agent
# REQUIRE: LOGIN
# KEYWORD: shutdown

. /etc/rc.subr

name="monitor_pfsense_agent"
rcvar="monitor_pfsense_agent_enable"
pidfile="/var/run/${name}.pid"
command="/usr/sbin/daemon"
agent_loop="/usr/local/libexec/monitor-pfsense-agent/monitor-pfsense-agent-loop.sh"
procname="${command}"
command_args="-p ${pidfile} -f -- ${agent_loop}"
required_files="/usr/local/etc/monitor-pfsense-agent.conf ${agent_loop}"

load_rc_config "$name"
: "${monitor_pfsense_agent_enable:=NO}"
onecmd="YES"

run_rc_command "$1"
