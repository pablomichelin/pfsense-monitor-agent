NODE_ENV=production
PORT=8088
DATABASE_URL=postgresql://monitor_pfsense:change-me@db:5432/monitor_pfsense?schema=public
SYSTEM_VERSION=0.1.0
TRUST_PROXY=false
TRUSTED_PROXY_IPS=192.168.100.253
HEARTBEAT_MAX_SKEW_SECONDS=300
NODE_DEGRADED_AFTER_SECONDS=90
NODE_OFFLINE_AFTER_SECONDS=300
NODE_RECONCILE_INTERVAL_SECONDS=30
AUTH_BOOTSTRAP_EMAIL=admin@systemup.inf.br
AUTH_BOOTSTRAP_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
AUTH_BOOTSTRAP_DISPLAY_NAME=SystemUp Admin
AUTH_SESSION_COOKIE_NAME=monitor_pfsense_session
AUTH_CSRF_COOKIE_NAME=monitor_pfsense_csrf
AUTH_SESSION_TTL_HOURS=12
AUTH_COOKIE_SECURE=true
GATEWAY_DEGRADED_LATENCY_MS=150
GATEWAY_DEGRADED_LOSS_PERCENT=5
AGENT_BOOTSTRAP_RELEASE_BASE_URL=https://downloads.exemplo/monitor-pfsense
# Comando de instalacao package (exibido no painel por firewall e apos rotacionar secret)
PACKAGE_RELEASE_VERSION=0.2.0
PACKAGE_RELEASE_SHA256=
# Opcional; default: GitHub do projeto
# PACKAGE_RELEASE_REPO_RAW_BASE=https://raw.githubusercontent.com/pablomichelin/pfsense-monitor-agent/main
# generate with: openssl rand -base64 32
NODE_SECRET_ENCRYPTION_KEY_BASE64=REPLACE_WITH_BASE64_32_BYTE_KEY
